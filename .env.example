# AskMore runtime configuration
# Copy to `.env` and adjust for your deployment.

# HTTP port exposed by the Express server. Must match the host-side
# mapping in docker-compose.yml (e.g. "8080:3000" expects PORT=3000).
PORT=3000

# Directory where the SQLite database file lives. Mounted as a
# named volume in the production compose override.
DATA_DIR=/app/data

# Node runtime mode. Always "production" inside the container.
NODE_ENV=production
